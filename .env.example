# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Transaction pooler URL — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL — used by Prisma migrate at build time (port 5432)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"
SESSION_SECRET="change-this-to-a-long-random-secret"

# ─── Seed (run once with: npm run db:seed) ───────────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
COMPANY_NAME=""
APP_NAME=""
ADDRESS_LOCATION_1=""
ADDRESS_LOCATION_2=""

# ─── Mail ────────────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Stripe (optional) ───────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=""

# ─── WhatsApp Cloud API (optional) ───────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN="change-this-token"
WHATSAPP_APP_SECRET=""

# ─── Public Website Enquiry Form (optional, comma-separated) ────────────────
# Origins allowed to POST to /api/public/web-form-leads. Defaults to totalproperty.ae.
PUBLIC_WEBSITE_ORIGIN="https://totalproperty.ae,https://www.totalproperty.ae"
